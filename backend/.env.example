# Backend Environment Variables Template
# Copy this to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# Email Service Configuration
EMAIL_SERVICE_KEY=your-secure-random-key-here
EMAIL_SERVER_URL=http://localhost:3002
SMTP_FROM=MySyntroMed <noreply@mysyntromed.com>

# Resend API (Optional - for production email)
# RESEND_API_KEY=your-resend-api-key

# Gmail SMTP (Optional - for development email)
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_PASS=your-app-password

# Sentry (Optional - for error tracking)
# SENTRY_DSN=your-sentry-dsn
