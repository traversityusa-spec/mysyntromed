# Server Configuration
PORT=3001
NODE_ENV=production

# Frontend URL (exact match, no trailing slash)
FRONTEND_ORIGIN=https://mysyntromed.com

# Firebase Configuration
FIREBASE_PROJECT_ID=mysyntromed-81242
SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firebase Service Account JSON (paste entire JSON content)
SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"mysyntromed-81242",...}

# Internal Service Authentication (must match email-server EMAIL_SERVICE_KEY)
EMAIL_SERVICE_KEY=mysyntromed-secure-email-api-key-2024

# Email Server URL (set after deploying email-server to Railway)
# Format: https://email-server-production-xxxx.up.railway.app
EMAIL_SERVER_URL=http://localhost:3002
