{
  "rules": {
    ".read": false,
    ".write": false,
    "typing": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "sounds": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid"
      }
    },
    "status": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid"
      }
    }
  }
}
