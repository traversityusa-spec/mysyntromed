# Email Server Configuration
PORT=3002

# Gmail SMTP - App Password (remove spaces from the app password!)
# Get from: Google Account > Security > App passwords (requires 2FA enabled)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=yourapppasswordwithoutspaces

# Internal Service Authentication (must match backend EMAIL_SERVICE_KEY)
EMAIL_SERVICE_KEY=generate-a-secure-random-string-here

# From address for emails
SMTP_FROM="MySyntroMed <noreply@mysyntromed.com>"
